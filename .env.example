# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api

# Supabase Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon/Public Key
# NOTE: Supabase now calls this "PUBLISHABLE_DEFAULT_KEY" in their dashboard,
# but this codebase supports both names. You can use either:
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# OR
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-publishable-key-here

# Database Connection String (Transaction Pooler recommended for serverless)
# Get from: Database Settings → Connection String → Transaction
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Optional: Application URL (for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
